# 🐋 Whale News Bot v2.0 - Environment Variables
# ================================================
# انسخ هذا الملف إلى .env واملأ القيم

# Telegram (مطلوب)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Channel (اختياري)
CHANNEL_ID=@your_channel_or_id
CHANNEL_LINK=https://t.me/your_channel
CHANNEL_NAME=Your Channel Name
SEND_TO_CHANNEL=false

# AI APIs (اختياري - يستخدم Google Translate كـ fallback)
GEMINI_API_KEY=your_gemini_key
GROQ_API_KEY=your_groq_key
OPENROUTER_API_KEY=your_openrouter_key

# GitHub Gist (للتخزين الدائم - اختياري)
GITHUB_TOKEN=your_github_token
GIST_ID_SETTINGS=your_gist_id
GIST_ID_SENT_NEWS=your_gist_id
GIST_ID_ALLOWED=your_gist_id

# Settings
TIMEZONE=Africa/Algiers
PORT=10000
RENDER_EXTERNAL_URL=https://your-app.onrender.com

# Run Mode (لـ GitHub Actions)
# RUN_MODE=oneshot
