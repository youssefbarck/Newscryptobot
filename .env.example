# ═══════════════════════════════════════════════════════════
# 🐋 Whale News Bot v2.0 — Environment Variables
# ═══════════════════════════════════════════════════════════

# ─── Telegram Bot (مطلوب) ───
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# ─── Telegram Channel (اختياري) ───
CHANNEL_ID=
CHANNEL_NAME=🐋 قناة الحيتان
CHANNEL_LINK=https://t.me/whale_signals_channel
SEND_TO_CHANNEL=false

# ─── Translation APIs ───
# واحد على الأقل مطلوب (Gemini هو الأفضل)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ─── GitHub Gist (مخزن دائم) ───
# يُستخدم لحفظ الإعدادات والأخبار المُرسلة والقائمة البيضاء
GITHUB_TOKEN=
GIST_ID_SETTINGS=
GIST_ID_SENT_NEWS=
GIST_ID_ALLOWED=

# ─── المستخدمون المسموحون (مفصولون بفواصل) ───
ALLOWED_USERS=

# ─── الإعدادات العامة ───
TIMEZONE=Africa/Algiers
PORT=10000
RUN_MODE=polling

# ─── Render (تلقائي — لا تحتاج لتعيينه يدوياً) ───
# RENDER_EXTERNAL_URL=  (يُعيّنه Render تلقائياً)

# ─── GitHub Actions (تلقائي) ───
# GITHUB_ACTIONS=true  (يُعيّنه GitHub تلقائياً)